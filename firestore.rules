// Firestore Security Rules for YSA GP Attendance System
// Copy and paste these rules into Firebase Console > Firestore > Rules tab
//
// BUG FIX: `assignedClass` renamed to `assignedClassId` throughout to match
// the canonical schema field and the deployed firestore.rules file.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper function to get user's role
    function getUserRole(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.role;
    }

    // BUG FIX: was `assignedClass` — now `assignedClassId` to match schema
    function getUserAssignedClass(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data.assignedClassId;
    }

    // Helper function to check if user is admin
    function isAdmin() {
      return isSignedIn() && getUserRole(request.auth.uid) == 'admin';
    }

    // Helper function to check if user is instructor
    function isInstructor() {
      return isSignedIn() && getUserRole(request.auth.uid) == 'instructor';
    }

    // Helper function to check if user is leader (read-only)
    function isLeader() {
      return isSignedIn() && getUserRole(request.auth.uid) == 'leader';
    }

    function isValidAttendanceStatus(status) {
      return status in ['present', 'absent'];
    }

    function sessionDoc(sessionId) {
      return get(/databases/$(database)/documents/attendanceSessions/$(sessionId)).data;
    }

    function instructorOwnsSession(sessionData) {
      return isInstructor() &&
        sessionData.createdBy == request.auth.uid &&
        sessionData.classId == getUserAssignedClass(request.auth.uid);
    }

    function instructorOwnsClass(classId) {
      return isInstructor() &&
        classId == getUserAssignedClass(request.auth.uid);
    }

    // ====================
    // USERS COLLECTION
    // ====================
    match /users/{userId} {
      // Users can read their own document
      allow read: if isSignedIn() && request.auth.uid == userId;

      // Admins can read all users
      allow read: if isAdmin();

      // Only admins can write to users
      allow write: if isAdmin();
    }

    // ====================
    // USER SESSIONS COLLECTION
    // ====================
    match /userSessions/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;

      allow create, update, delete: if isSignedIn() &&
        request.auth.uid == userId;
    }

    // ====================
    // CLASSES COLLECTION
    // ====================
    match /classes/{classId} {
      // Authenticated users can read classes
      allow read: if isSignedIn();

      // Only admins can create, update, or delete classes
      allow create, update, delete: if isAdmin();
    }

    // ====================
    // STUDENTS COLLECTION
    // ====================
    match /students/{studentId} {
      // Authenticated users can read students
      allow read: if isSignedIn();

      // Admins can do anything
      allow create, update, delete: if isAdmin();

      allow create: if isInstructor() &&
        request.resource.data.classId == getUserAssignedClass(request.auth.uid);

      allow update: if isInstructor() &&
        resource.data.classId == getUserAssignedClass(request.auth.uid) &&
        request.resource.data.classId == getUserAssignedClass(request.auth.uid);

      allow delete: if isInstructor() &&
        resource.data.classId == getUserAssignedClass(request.auth.uid);
    }

    // ====================
    // ATTENDANCE SESSIONS COLLECTION
    // ====================
    match /attendanceSessions/{sessionId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();

      allow create: if instructorOwnsSession(request.resource.data);

      allow update: if instructorOwnsSession(resource.data) &&
        instructorOwnsSession(request.resource.data);

      allow delete: if instructorOwnsSession(resource.data);
    }

    // ====================
    // ATTENDANCE RECORDS COLLECTION
    // ====================
    match /attendanceRecords/{recordId} {
      allow read: if isSignedIn();
      allow create, update, delete: if isAdmin();

      allow create: if isInstructor() &&
        isValidAttendanceStatus(request.resource.data.status) &&
        instructorOwnsSession(sessionDoc(request.resource.data.sessionId));

      allow update: if isInstructor() &&
        isValidAttendanceStatus(request.resource.data.status) &&
        instructorOwnsSession(sessionDoc(resource.data.sessionId)) &&
        request.resource.data.sessionId == resource.data.sessionId &&
        request.resource.data.studentId == resource.data.studentId;

      allow delete: if isInstructor() &&
        instructorOwnsSession(sessionDoc(resource.data.sessionId));
    }

    // ====================
    // PERFORMANCE RATINGS COLLECTION
    // ====================
    match /performanceRatings/{recordId} {
      allow read: if isAdmin() || isLeader() || (
        isInstructor() &&
        resource.data.classId == getUserAssignedClass(request.auth.uid)
      );

      allow create, update, delete: if isAdmin();

      allow create: if instructorOwnsClass(request.resource.data.classId) &&
        request.resource.data.instructorId == request.auth.uid &&
        request.resource.data.rating is number &&
        request.resource.data.rating >= 1 &&
        request.resource.data.rating <= 5;

      allow update: if resource.data.classId == getUserAssignedClass(request.auth.uid) &&
        resource.data.instructorId == request.auth.uid &&
        request.resource.data.classId == resource.data.classId &&
        request.resource.data.studentId == resource.data.studentId &&
        request.resource.data.instructorId == resource.data.instructorId &&
        request.resource.data.rating is number &&
        request.resource.data.rating >= 1 &&
        request.resource.data.rating <= 5;
    }

    // Deny all other access by default
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

/*
RULE SUMMARY:
=============

ADMINS:
- Full read/write access to all collections

INSTRUCTORS:
- Can read all data
- Can manage students in their `assignedClassId` class only
- Can create attendance sessions for their class
- Can modify attendance records for their sessions

LEADERS:
- Read-only access to all data

UNAUTHENTICATED USERS:
- No access (denied by default)
*/
